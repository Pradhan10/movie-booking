        <mxCell id="booking-service-header" value="Core Business Logic with Transaction Management" style="text;strokeColor=none;fillColor=none;align=center;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=10;fontStyle=2" vertex="1" parent="booking-service">
