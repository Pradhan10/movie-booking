        <mxCell id="booking-repos-list" value="SeatRepository:&#xa;  @Lock(PESSIMISTIC_WRITE)&#xa;  findByIdsAndStatusForUpdate(ids, status)&#xa;    SELECT ... FOR UPDATE SKIP LOCKED&#xa;  &#xa;  updateStatusWithOptimisticLock(seatId, newStatus, version)&#xa;    UPDATE seat WHERE id=? AND version=?&#xa;&#xa;BookingRepository, PaymentRepository" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=9;fontFamily=Courier New;" vertex="1" parent="booking-repos">
          <mxGeometry y="58" width="400" height="142" as="geometry" />
        </mxCell>
        <mxCell id="redis-booking" value="Redis 7.2" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1000" y="1010" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="redis-booking-usage" value="Booking Keys:&#xa;lock:seat:{id} - TTL: 30s (SETNX)&#xa;seat:hold:{sessionId} - TTL: 10min&#xa;  Hash: seatIds, userId, expiresAt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1140" y="1010" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="postgres-booking" value="PostgreSQL 15" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="600" y="1560" width="140" height="90" as="geometry" />
        </mxCell>
        <mxCell id="booking-tables" value="Tables:&#xa;- booking&#xa;- seat (with @Version)&#xa;- booking_seat&#xa;- payment&#xa;- user_account" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="780" y="1560" width="160" height="90" as="geometry" />
        </mxCell>
        <mxCell id="rabbitmq" value="RabbitMQ 3.12" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1000" y="1420" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rabbitmq-events" value="Events Published:&#xa;- BookingConfirmedEvent&#xa;- BookingCancelledEvent&#xa;- PaymentSuccessEvent&#xa;&#xa;Consumers:&#xa;- NotificationService (future)&#xa;- AnalyticsService (future)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1180" y="1390" width="200" height="140" as="geometry" />
        </mxCell>
        <mxCell id="common-module" value="COMMON MODULE (Shared)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=16;fontStyle=1;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="1450" y="120" width="450" height="600" as="geometry" />
        </mxCell>
        <mxCell id="common-enums" value="Enums" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1480" y="170" width="200" height="160" as="geometry" />
        </mxCell>
        <mxCell id="common-enums-list" value="BookingStatus:&#xa;  PENDING, CONFIRMED,&#xa;  CANCELLED, REFUNDED&#xa;&#xa;SeatStatus:&#xa;  AVAILABLE, HELD,&#xa;  BOOKED, BLOCKED&#xa;&#xa;SeatCategory:&#xa;  PREMIUM, NORMAL, VIP&#xa;&#xa;ShowStatus:&#xa;  ACTIVE, CANCELLED, COMPLETED&#xa;&#xa;PaymentStatus:&#xa;  INITIATED, SUCCESS,&#xa;  FAILED, REFUNDED" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=9;" vertex="1" parent="common-enums">
          <mxGeometry y="30" width="200" height="130" as="geometry" />
        </mxCell>
        <mxCell id="common-dtos" value="DTOs (Data Transfer Objects)" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1700" y="170" width="180" height="160" as="geometry" />
        </mxCell>
        <mxCell id="common-dtos-list" value="SeatDTO:&#xa;  seatId, seatNumber,&#xa;  category, price&#xa;&#xa;ShowDTO:&#xa;  showId, movieName,&#xa;  theatreName, showTime,&#xa;  availableSeats&#xa;&#xa;OfferDTO:&#xa;  offerId, offerName,&#xa;  discountPercentage,&#xa;  applicableTo" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=9;" vertex="1" parent="common-dtos">
          <mxGeometry y="30" width="180" height="130" as="geometry" />
        </mxCell>
        <mxCell id="concurrency-box" value="4-LAYER CONCURRENCY DEFENSE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=16;fontStyle=1;verticalAlign=top;align=center;" vertex="1" parent="1">
          <mxGeometry x="1450" y="800" width="450" height="400" as="geometry" />
        </mxCell>
        <mxCell id="layer1" value="Layer 1: Redis Distributed Lock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1480" y="850" width="390" height="70" as="geometry" />
        </mxCell>
        <mxCell id="layer1-detail" value="SETNX lock:seat:{id} with 30s TTL&#xa;Prevents concurrent access across all instances&#xa;Released after operation completes" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1490" y="870" width="370" height="40" as="geometry" />
        </mxCell>
        <mxCell id="layer2" value="Layer 2: Pessimistic DB Lock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1480" y="940" width="390" height="70" as="geometry" />
        </mxCell>
        <mxCell id="layer2-detail" value="SELECT FOR UPDATE SKIP LOCKED&#xa;Database-level row lock during transaction&#xa;Other transactions skip locked rows" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1490" y="960" width="370" height="40" as="geometry" />
        </mxCell>
        <mxCell id="layer3" value="Layer 3: Optimistic Lock (@Version)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1480" y="1030" width="390" height="70" as="geometry" />
        </mxCell>
        <mxCell id="layer3-detail" value="@Version column on Seat entity&#xa;UPDATE seat SET ... WHERE id=? AND version=?&#xa;Throws OptimisticLockingFailureException if stale" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1490" y="1050" width="370" height="40" as="geometry" />
        </mxCell>
        <mxCell id="layer4" value="Layer 4: DB Unique Constraint" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1480" y="1120" width="390" height="70" as="geometry" />
        </mxCell>
        <mxCell id="layer4-detail" value="UNIQUE constraint: unique_seat_per_show&#xa;Final database-level protection&#xa;PostgreSQL ensures data integrity" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1490" y="1140" width="370" height="40" as="geometry" />
        </mxCell>
        <mxCell id="flow-box" value="BOOKING FLOW SEQUENCE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;fontStyle=1;verticalAlign=top;align=center;" vertex="1" parent="1">
          <mxGeometry x="1450" y="1250" width="450" height="640" as="geometry" />
        </mxCell>
        <mxCell id="step1" value="Step 1: HOLD SEATS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1480" y="1300" width="390" height="30" as="geometry" />
        </mxCell>
        <mxCell id="step1-detail" value="Client: POST /bookings/hold&#xa;  Body: {sessionId, seatIds, userId, showId}&#xa;&#xa;Server:&#xa;  1. Redis: acquireLock(each seatId) - SETNX&#xa;  2. DB: SELECT ... FOR UPDATE SKIP LOCKED&#xa;  3. DB: UPDATE seat SET status=HELD, version=version+1&#xa;  4. Redis: HSET seat:hold:{sessionId} - 10min TTL&#xa;  5. Redis: releaseLock(each seatId)&#xa;&#xa;Response: {sessionId, seatIds, expiresAt, success}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#6c8ebf;fontSize=9;align=left;verticalAlign=top;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1480" y="1335" width="390" height="130" as="geometry" />
        </mxCell>
        <mxCell id="step2" value="Step 2: CREATE BOOKING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1480" y="1485" width="390" height="30" as="geometry" />
        </mxCell>
        <mxCell id="step2-detail" value="Client: POST /bookings&#xa;  Body: {sessionId, userId, showId, seatIds, email}&#xa;&#xa;Server:&#xa;  1. Redis: getHeldSeats(sessionId) - validate hold&#xa;  2. DB: SELECT seats (check still HELD)&#xa;  3. Calculate totalAmount, apply offers (OfferService)&#xa;  4. DB: INSERT booking (status=PENDING)&#xa;  5. Payment: initiatePayment() -&gt; PaymentGateway&#xa;&#xa;Response: {bookingId, paymentUrl, paymentId, amount}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff9e6;strokeColor=#d6b656;fontSize=9;align=left;verticalAlign=top;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1480" y="1520" width="390" height="130" as="geometry" />
        </mxCell>
        <mxCell id="step3" value="Step 3: CONFIRM BOOKING (After Payment)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1480" y="1670" width="390" height="30" as="geometry" />
        </mxCell>
        <mxCell id="step3-detail" value="Client: POST /bookings/{bookingId}/confirm?paymentId=&#xa;&#xa;Server:&#xa;  1. DB: SELECT payment (verify status=SUCCESS)&#xa;  2. DB: UPDATE seat status=BOOKED WHERE version=X&#xa;     (Optimistic Lock - if version mismatch, retry)&#xa;  3. DB: UPDATE booking status=CONFIRMED&#xa;  4. RabbitMQ: publish BookingConfirmedEvent&#xa;  5. Redis: delete seat:hold:{sessionId}&#xa;&#xa;Response: {bookingId, bookingReference, qrCode}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#82b366;fontSize=9;align=left;verticalAlign=top;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1480" y="1705" width="390" height="140" as="geometry" />
        </mxCell>
        <mxCell id="step4" value="Step 4: ASYNC EVENT HANDLING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1480" y="1860" width="390" height="30" as="geometry" />
        </mxCell>
        <mxCell id="step4-detail" value="RabbitMQ -&gt; NotificationService (future):&#xa;  - Send booking confirmation email&#xa;  - Send SMS with QR code&#xa;  - Retry on failure (exponential backoff)&#xa;  - Store in message center if all retries fail" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#9673a6;fontSize=9;align=left;verticalAlign=top;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1480" y="1895" width="390" height="70" as="geometry" />
        </mxCell>
        <mxCell id="arrow-catalog-service" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" parent="1" source="catalog-controller" target="catalog-service">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-catalog-repos" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#d6b656;" edge="1" parent="1" source="catalog-service" target="catalog-repos">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-catalog-redis" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#d79b00;dashed=1;" edge="1" parent="1" source="catalog-service" target="redis-cache-service">
