        </mxCell>
        <mxCell id="booking-service-line1" value="" style="line;strokeWidth=1;fillColor=none;align=left;verticalAlign=middle;spacingTop=-1;spacingLeft=3;spacingRight=3;rotatable=0;labelPosition=right;points=[];portConstraint=eastwest;strokeColor=inherit;" vertex="1" parent="booking-service">
          <mxGeometry y="50" width="400" height="8" as="geometry" />
        </mxCell>
        <mxCell id="booking-service-methods" value="+ holdSeats(request): HoldSeatsResponse&#xa;  1. Pessimistic lock: findByIdsForUpdate()&#xa;  2. Redis distributed lock: acquireLock()&#xa;  3. Update seat status to HELD&#xa;  4. Store hold in Redis (10 min TTL)&#xa;&#xa;+ createBooking(request): Booking&#xa;  - Validate hold exists&#xa;  - Calculate price with offers&#xa;  - Create booking (status: PENDING)&#xa;&#xa;+ confirmBooking(bookingId, paymentId): Booking&#xa;  1. Optimistic lock: @Version check&#xa;  2. Update seats to BOOKED&#xa;  3. Update booking to CONFIRMED&#xa;  4. Publish BookingConfirmedEvent&#xa;&#xa;+ cancelBooking(bookingId, reason)&#xa;  - Release seats&#xa;  - Publish BookingCancelledEvent" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=9;" vertex="1" parent="booking-service">
          <mxGeometry y="58" width="400" height="182" as="geometry" />
        </mxCell>
        <mxCell id="seat-lock-service" value="SeatLockService" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="950" width="320" height="200" as="geometry" />
        </mxCell>
        <mxCell id="seat-lock-header" value="Redis Distributed Locking (Layer 1 Defense)" style="text;strokeColor=none;fillColor=none;align=center;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=10;fontStyle=2" vertex="1" parent="seat-lock-service">
          <mxGeometry y="30" width="320" height="20" as="geometry" />
        </mxCell>
        <mxCell id="seat-lock-line1" value="" style="line;strokeWidth=1;fillColor=none;align=left;verticalAlign=middle;spacingTop=-1;spacingLeft=3;spacingRight=3;rotatable=0;labelPosition=right;points=[];portConstraint=eastwest;strokeColor=inherit;" vertex="1" parent="seat-lock-service">
          <mxGeometry y="50" width="320" height="8" as="geometry" />
        </mxCell>
        <mxCell id="seat-lock-methods" value="+ acquireLock(seatId, txnId): boolean&#xa;  Redis: SETNX lock:seat:{id} TTL:30s&#xa;&#xa;+ releaseLock(seatId, txnId)&#xa;  Redis: DEL lock:seat:{id}&#xa;&#xa;+ holdSeats(sessionId, seatIds, userId, expires)&#xa;  Redis: HSET seat:hold:{session} TTL:10min&#xa;&#xa;+ getHeldSeats(sessionId): Set&lt;Long&gt;&#xa;+ releaseHold(sessionId)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=9;" vertex="1" parent="seat-lock-service">
          <mxGeometry y="58" width="320" height="142" as="geometry" />
        </mxCell>
