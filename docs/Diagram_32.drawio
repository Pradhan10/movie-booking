        <mxCell id="arrow-redis-db-catalog" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#b85450;" edge="1" parent="1" source="redis-cache-service" target="redis-db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-repos-pg-catalog" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" parent="1" source="catalog-repos" target="postgres-catalog">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-booking-service" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#d6b656;" edge="1" parent="1" source="booking-controller" target="booking-service">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-booking-payment" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#d6b656;dashed=1;" edge="1" parent="1" source="booking-controller" target="payment-service">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-booking-seatlock" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#b85450;dashed=1;" edge="1" parent="1" source="booking-service" target="seat-lock-service">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-booking-event" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#9673a6;dashed=1;" edge="1" parent="1" source="booking-service" target="event-publisher">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-booking-repos" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#9673a6;" edge="1" parent="1" source="booking-service" target="booking-repos">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-seatlock-redis" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#b85450;" edge="1" parent="1" source="seat-lock-service" target="redis-booking">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-event-rabbitmq" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#9673a6;" edge="1" parent="1" source="event-publisher" target="rabbitmq">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-repos-pg-booking" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" parent="1" source="booking-repos" target="postgres-booking">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="test-box" value="AUTOMATED TESTS" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=16;fontStyle=1;verticalAlign=top;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="1950" width="1200" height="350" as="geometry" />
        </mxCell>
        <mxCell id="test1" value="BookingServiceConcurrencyTest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="150" y="2000" width="500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="test1-detail" value="Purpose: Validates 4-layer concurrency defense&#xa;&#xa;Test Scenario:&#xa;  - 10 threads attempt to book SAME seat simultaneously&#xa;  - ExecutorService with CountDownLatch for synchronization&#xa;  - All threads call holdSeats() at exact same time&#xa;&#xa;Expected Result:&#xa;  - 1 thread succeeds (gets the seat)&#xa;  - 9 threads fail (SeatUnavailableException)&#xa;&#xa;Validates:&#xa;  Layer 1: Redis lock prevents race conditions&#xa;  Layer 2: DB pessimistic lock ensures consistency&#xa;  Layer 3: @Version column detects conflicts&#xa;  Layer 4: Unique constraint is last safety net&#xa;&#xa;Tech: JUnit 5, Testcontainers (real Postgres + Redis)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#b85450;fontSize=9;align=left;verticalAlign=top;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="150" y="2035" width="500" height="245" as="geometry" />
        </mxCell>
        <mxCell id="test2" value="ShowCatalogServiceIntegrationTest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="700" y="2000" width="500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="test2-detail" value="Purpose: Validates caching and query logic&#xa;&#xa;Test Scenarios:&#xa;  1. First query hits database&#xa;  2. Second query hits Redis cache (85% hit rate)&#xa;  3. Cache TTL expiration works correctly&#xa;  4. Complex queries with filters return correct data&#xa;&#xa;Validates:&#xa;  - Cache-aside pattern implementation&#xa;  - TTL configuration (5min shows, 15min theatres)&#xa;  - Repository query correctness&#xa;  - DTO mapping&#xa;&#xa;Tech: JUnit 5, Testcontainers (real Postgres + Redis)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#6c8ebf;fontSize=9;align=left;verticalAlign=top;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="700" y="2035" width="500" height="245" as="geometry" />
        </mxCell>
        <mxCell id="legend-box" value="LEGEND" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=14;fontStyle=1;verticalAlign=top;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="120" width="280" height="320" as="geometry" />
        </mxCell>
        <mxCell id="leg1" value="REST Controller" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="130" y="160" width="220" height="30" as="geometry" />
        </mxCell>
