        <mxCell id="kpi-list" value="✓ Booking Success Rate: &gt; 95%&#xa;✓ Payment Success Rate: &gt; 98%&#xa;✓ API Latency P99: &lt; 500ms&#xa;✓ Search Response Time: &lt; 200ms&#xa;✓ Seat Lock Availability: 99.9%&#xa;✓ Platform Uptime: 99.99%&#xa;✓ Notification Delivery: &gt; 99%&#xa;✓ Concurrent Users: 100K&#xa;✓ Bookings per minute: 10K" style="text;html=1;strokeColor=#666666;fillColor=#ffffff;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1580" y="460" width="460" height="160" as="geometry" />
