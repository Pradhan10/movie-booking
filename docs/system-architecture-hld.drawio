        <mxCell id="scaling-box" value="SCALING STRATEGY" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1550" y="1100" width="520" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="scaling-list" value="✓ Horizontal scaling: All services stateless&#xa;✓ Database: Read replicas (3-5 per region)&#xa;✓ Redis: Cluster mode (3 master + 3 replica)&#xa;✓ CDN: Cache static content (posters, assets)&#xa;✓ Rate limiting: API Gateway level&#xa;✓ Circuit breaker: Resilience4j&#xa;✓ Bulkhead pattern: Isolate critical services" style="text;html=1;strokeColor=#666666;fillColor=#ffffff;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1580" y="1140" width="460" height="120" as="geometry" />
