          <mxGeometry x="1550" y="880" width="520" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="deployment-list" value="✓ Cloud: AWS (Primary) / Multi-cloud ready&#xa;✓ Container: Docker + Kubernetes (EKS)&#xa;✓ CI/CD: Jenkins / GitHub Actions&#xa;✓ Infrastructure: Terraform&#xa;✓ Service Mesh: Istio (optional)&#xa;✓ Regions: Multi-region (US, EU, Asia)&#xa;✓ Auto-scaling: HPA based on CPU/RPS&#xa;✓ Database: RDS Multi-AZ&#xa;✓ CDN: CloudFront for static assets" style="text;html=1;strokeColor=#666666;fillColor=#ffffff;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1580" y="920" width="460" height="160" as="geometry" />
