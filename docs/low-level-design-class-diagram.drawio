        <!-- Design Patterns Box -->
        <mxCell id="patterns-box" value="DESIGN PATTERNS APPLIED" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1340" y="540" width="1180" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="pattern1" value="1. Repository Pattern&#xa;   Abstracts data access logic&#xa;   Easy to mock for testing" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1380" y="580" width="260" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="pattern2" value="2. Service Layer Pattern&#xa;   Business logic encapsulation&#xa;   Transaction boundaries" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1680" y="580" width="240" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="pattern3" value="3. DTO Pattern&#xa;   Decouples API from domain&#xa;   Version API independently" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1960" y="580" width="240" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="pattern4" value="4. Saga Pattern&#xa;   Distributed transactions&#xa;   Booking → Payment → Notification" style="text;html=1;strokeColor=#d79b00;fillColor=#ffe6cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="2240" y="580" width="240" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="pattern5" value="5. Event-Driven Architecture&#xa;   Async communication&#xa;   Loose coupling between services" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1380" y="670" width="260" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="pattern6" value="6. Optimistic Locking&#xa;   Version-based concurrency control&#xa;   Prevents lost updates" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1680" y="670" width="240" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="pattern7" value="7. Cache-Aside Pattern&#xa;   Check cache → Miss → DB → Update cache&#xa;   Reduces DB load" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1960" y="670" width="240" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="pattern8" value="8. Strategy Pattern&#xa;   Offer calculation strategies&#xa;   Different discount types" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="2240" y="670" width="240" height="60" as="geometry" />
        </mxCell>
        
