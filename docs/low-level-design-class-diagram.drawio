        <mxCell id="ex-rel4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;endArrow=block;endFill=0;dashed=1;" edge="1" parent="1" source="hold-expired-ex" target="base-exception">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Sequence Diagram Reference -->
        <mxCell id="sequence-note" value="BOOKING FLOW SEQUENCE" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1340" y="1120" width="1180" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="sequence-diagram" value="1. Client → BookingController.holdSeats()&#xa;2. BookingController → BookingService.holdSeats()&#xa;3. BookingService → SeatRepository.findByIdsForUpdate() [Pessimistic Lock]&#xa;4. BookingService → Validate seats AVAILABLE&#xa;5. BookingService → SeatLockService.acquireLock() [Redis SETNX]&#xa;6. BookingService → SeatRepository.updateStatus(HELD, version++) [Optimistic Lock]&#xa;7. BookingService → SeatLockService.holdSeats(TTL=10min)&#xa;8. Return HoldSeatsResponse&#xa;&#xa;9. Client → BookingController.createBooking()&#xa;10. BookingController → BookingService.createBooking()&#xa;11. BookingService → Validate hold not expired&#xa;12. BookingService → OfferService.calculateDiscount()&#xa;13. BookingService → BookingRepository.save() [START TRANSACTION]&#xa;14. BookingService → SeatRepository.updateStatus(HELD) [Keep held]&#xa;15. BookingService → Return Booking with payment URL [COMMIT]&#xa;&#xa;16. Client redirects to Payment Gateway&#xa;17. Payment Gateway → PaymentService.handleWebhook()&#xa;18. PaymentService → Validate signature&#xa;19. PaymentService → BookingService.confirmBooking() [If SUCCESS]&#xa;20. BookingService → SeatRepository.updateStatus(BOOKED) [TRANSACTION]&#xa;21. BookingService → SeatLockService.releaseHold()&#xa;22. BookingService → EventPublisher.publishBookingConfirmed()&#xa;23. NotificationService (async) ← Listens to event&#xa;24. NotificationService → Send email/SMS&#xa;25. If notification fails: Log and retry (max 3 attempts)" style="text;html=1;strokeColor=#666666;fillColor=#ffffff;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1380" y="1160" width="1100" height="420" as="geometry" />
        </mxCell>
        
        <!-- API Contracts -->
        <mxCell id="api-box" value="API CONTRACTS (RESTful)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1340" y="1610" width="1180" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="api-catalog" value="CATALOG SERVICE APIs&#xa;&#xa;GET  /api/v1/shows?movieId={id}&amp;date={date}&amp;city={city}&#xa;GET  /api/v1/shows/theatre/{theatreId}?date={date}&#xa;GET  /api/v1/shows/{showId}&#xa;GET  /api/v1/offers?city={city}&amp;theatreId={id}" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1380" y="1650" width="540" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="api-booking" value="BOOKING SERVICE APIs&#xa;&#xa;POST /api/v1/bookings/hold        # Hold seats&#xa;POST /api/v1/bookings              # Create booking&#xa;POST /api/v1/bookings/{id}/confirm # Confirm after payment&#xa;POST /api/v1/bookings/{id}/cancel  # Cancel booking&#xa;GET  /api/v1/bookings/{id}          # Get details&#xa;GET  /api/v1/bookings/user/{userId} # User's bookings" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1960" y="1650" width="520" height="130" as="geometry" />
        </mxCell>
        
        <!-- Arrows from controller to service -->
        <mxCell id="arrow-cat-ctrl-svc" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;strokeColor=#666666;dashed=1;startArrow=none;startFill=0;endArrow=open;endFill=0;" edge="1" parent="1" source="catalog-controller-fields" target="catalog-service-class">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
